{
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.next/**": true,
    "**/.turbo/**": true,
    "**/.vercel/**": true,
    "**/coverage/**": true,
    "**/node_modules/**": true
  },
  "search.exclude": {
    "**/.next": true,
    "**/.turbo": true,
    "**/.vercel": true,
    "**/coverage": true,
    "**/node_modules": true
  },
  "files.exclude": {
    "**/.next": true,
    "**/.turbo": true,
    "**/.vercel": true
  },
  "typescript.disableAutomaticTypeAcquisition": true,
  "typescript.tsserver.maxTsServerMemory": 2048
}
